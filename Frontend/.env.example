# Production (dietdesk.online): leave VITE_API_URL UNSET.
# The app auto-uses https://dietdesk.online/backend (Vercel proxy to Hugging Face).
# Do NOT set VITE_API_URL to the HF URL directly — causes CORS/network failures.
# Local dev only:
# VITE_API_URL=http://127.0.0.1:8000

# Sentry (production only — leave unset for local dev)
# VITE_SENTRY_DSN=https://<key>@<org>.ingest.sentry.io/<project>
# VITE_SENTRY_RELEASE=<git-commit-sha>
# VITE_SENTRY_ENVIRONMENT=production
# VITE_ENABLE_SENTRY_TEST=true  # temporary — remove after verification
